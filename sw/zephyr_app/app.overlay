/ {
    chosen {
        zephyr,console = &uart0;
        zephyr,shell-uart = &uart0;
    };

    soc {
        efpga: efpga@10000000 {
            compatible = "fabulous,efpga-wishbone";
            reg = <0x10000000 0x1000>;
            status = "okay";
        };
    };
};

&uart0 {
    status = "okay";
    current-speed = <19200>;
};

&dmem {
    reg = <0x00008000 32768>;
};

&imem {
    reg = <0x00000000 32768>;
};